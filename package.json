{
  "name": "instollar-sdk",
  "version": "1.0.0",
  "description": "SDK for Instollar - React (web) and Expo apps",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/core/api/index.d.ts",
      "import": "./dist/core/api/index.mjs",
      "require": "./dist/core/api/index.js"
    },
    "./storage": {
      "types": "./dist/core/storage/index.d.ts",
      "import": "./dist/core/storage/index.mjs",
      "require": "./dist/core/storage/index.js"
    },
    "./toast": {
      "types": "./dist/core/toast/index.d.ts",
      "import": "./dist/core/toast/index.mjs",
      "require": "./dist/core/toast/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepare": "npm run build"
  },
  "keywords": [
    "instollar",
    "sdk",
    "api",
    "react",
    "expo",
    "cross-platform"
  ],
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0"
  },
  "peerDependencies": {
    "expo-secure-store": ">=10.0.0"
  },
  "peerDependenciesMeta": {
    "expo-secure-store": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "expo-secure-store": "^12.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
